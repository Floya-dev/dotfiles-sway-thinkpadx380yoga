# Mod key(s)
set $mod Mod4

# Movement keys
set $left h
set $down j
set $up k
set $right l

# Essential apps
set $term kitty
set $term_float ~/.config/sway/scripts/floating.sh kitty
set $menu fuzzel --counter -f "BigBlueTerm437 Nerd Font Mono" --icon-theme="WhiteSur-dark" -l 11 -a center --show-actions
set $logman wlogout
set $files nemo
set $files_float ~/.config/sway/scripts/floating.sh nemo

# Internet
set $brow2 chromium
set $priv librewolf

# Utilities
#set $lock swaylock --clock --indicator --color 000000
set $lock swaylock --clock --indicator -i /home/ondrii/Pictures/Wallpapers/SOSKOLIN.png
set $clip clipman pick --tool=CUSTOM --tool-args="fuzzel -d"
set $scr pgrep -x hyprshot > /dev/null || hyprshot -m region --clipboard-only
set $scr_screen pgrep -x hyprshot /dev/null || hyprshot -m output -o ~/Pictures/Screenshots/
set $chnwall ~/.config/sway/scripts/wallpaper-change.sh
set $pick hyprpicker --format=hex -n -a
set $ide vscodium
set $updatetui kitty parui -p=yay
set $notif ~/.config/sway/scripts/notifications.sh
set $notif-client swaync-client -t
set $emoji BEMOJI_PICKER_CMD="fuzzel -d" bemoji -c -n
set $comms legcord


